{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$id": "module-schema.json",
	
	"$defs": {
		"_id": {
			"type": "object",
			"properties": {
				"key": {"$ref": "commons.json#/$defs/_key"},
				"label": {"$ref": "commons.json#/$defs/_label"},
				"comment": {"$ref": "commons.json#/$defs/_comment"},
				"domain-type": {"$ref": "commons.json#/$defs/_key"}
			},
			"required": [
				"key",
				"label",
				"domain-type"
			],
			"additionalProperties": false
		},
		"_attribute": {
			"type": "object",
		    	"properties": {
		    		"label": { "$ref": "commons.json#/$defs/_label" },
		      	"comment": { "$ref": "commons.json#/$defs/_comment" },
		      	"domain-type": { "$ref": "commons.json#/$defs/_key" },
		      	"required": { "type": "boolean" }
		    	},
		    "required": [
		    		"label",
		      	"domain-type",
		      	"required"
		    ],
		    "additionalProperties": false
		},
		"_link": {
		    	"properties": {
				"label": {"$ref": "commons.json#/$defs/_label"},
				"comment": {"$ref": "commons.json#/$defs/_comment"},
				"target-entity-key": {"$ref": "commons.json#/$defs/_key"},
				"stereotype": {
					"type": "string",
					"enum": [
						"MANY_TO_ONE",
						"MANY_TO_OPTIONAL",
						"ONE_TO_ONE",
						"ONE_TO_OPTIONAL",
						"MANY_TO_MANY"
					]
				}
		    	},
			"required": [
				"label",
			    "target-entity-key",
				"stereotype"
			],
			"additionalProperties": false
		}
	},	
	
	"type": "object",
	"properties": {
		"module-info": {
			"type": "object",
			"description": "Metadata describing the current module.",
			"properties": {
				"key": {"$ref": "commons.json#/$defs/_key"},
				"comment": {"$ref": "commons.json#/$defs/_comment"},
				"tags": {"$ref": "commons.json#/$defs/_string-array"}
			},
			"required": [
				"key",
				"tags"
			],
			"additionalProperties": false
		},
		
		"imports": {
			"type": "object",
			"description": "Defines external libraries and modules that this module depends on.",
			"properties": {
				"libraries": {"$ref": "commons.json#/$defs/_string-array"},
				"modules": {"$ref": "commons.json#/$defs/_string-array"}
			},
			"required": [
				"libraries",
				"modules"
			],
			"additionalProperties": false
		},
		
		"entities": {
			"type": "object",
			"description": "Map of entity definitions, where each property name is an entity key and its value is the entity object.",
		 	"propertyNames": {"$ref": "commons.json#/$defs/_key"},
			"additionalProperties": {
				"type": "object",
				"properties": {
					"comment": {"$ref": "commons.json#/$defs/_comment"},
					"id": { 
						"$ref": "#/$defs/_id",
						"description": "Definition of the id or primary key for the entity."
					},
					"attributes": { 		
						"type": "object",
						"propertyNames": {"$ref": "commons.json#/$defs/_key"},
						"additionalProperties": {"$ref": "#/$defs/_attribute"}
					},
					"links": { 		
						"type": "object",
						"propertyNames": {"$ref": "commons.json#/$defs/_key"},
						"additionalProperties": {"$ref": "#/$defs/_link"}
					}
				},
				"required": [
					"id",
					"attributes", 
					"links"
				],
				"additionalProperties": false
			}
		},
		"value-objects": {
			"type": "object",
			"description": "Map of value object definitions, where each property name is a value object key, and its value is the value object object.",
		 	"propertyNames": {"$ref": "commons.json#/$defs/_key"},
			"additionalProperties": {
				"type":"object",
				"properties": {
					"comment": {"$ref": "commons.json#/$defs/_comment"},
					"attributes": { 		
						"type": "object",
						"propertyNames": {"$ref": "commons.json#/$defs/_key"},
						"additionalProperties": {"$ref": "#/$defs/_attribute"}
					}
				}, 	
				"required": [
					"attributes"
				],
				"additionalProperties": false
			}
		}
	},
	"required": [
		"module-info",
		"imports",
		"entities",
		"value-objects"
	],
	"additionalProperties": false
}