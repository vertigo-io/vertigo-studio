{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	
	"$defs": {
		"_key": {
			"type": "string",
			"pattern": "^([a-z]+:)?[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"_domain-type": {
			"type": "string",
			"pattern": "^([a-z]+:)[a-z]+(-[a-z]+)*$"
		},
		"_comment": {
			"type": "string",
			"maxLength": 500
		},
		"_label": {
			"type": "string",
			"maxLength": 100
		},
		"_string-array": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"uniqueItems": true
		},
		"_link": {
			"type": "object",
			"properties": {
				"key": {"$ref": "#/$defs/_key"},
				"label": {"$ref": "#/$defs/_label"},
				"comment": {"$ref": "#/$defs/_comment"},
				"target-entity-key": {"$ref": "#/$defs/_key"},
				"required": {"type": "boolean"},
				"stereotype": {
					"type": "string",
					"enum": [
						"MANY_TO_ONE",
						"ONE_TO_ONE",
						"MANY_TO_MANY"
					]
				}
			},
			"required": [
				"key",
				"label",
				"target-entity-key",
				"required",
				"stereotype"
			]
		},
		"_attributes": {
			"type": "object",
		 	"propertyNames": {"$ref": "#/$defs/_key"},
			"additionalProperties": {
			    	"type": "object",
			    	"properties": {
			    		"label": { "$ref": "#/$defs/_label" },
			      	"comment": { "$ref": "#/$defs/_comment" },
			      	"domain-type": { "$ref": "#/$defs/_domain-type" },
			      	"required": { "type": "boolean" }
			    	},
			    "required": [
			    		"label",
			      	"domain-type",
			      	"required"
			    ],
			    "additionalProperties": false
			}
		}
	},
	
	"type": "object",
	"properties": {
		"module-info": {
			"type": "object",
			"properties": {
				"key": {"$ref": "#/$defs/_key"},
				"comment": {"$ref": "#/$defs/_comment"},
				"tags": {"$ref": "#/$defs/_string-array"}
			},
			"required": [
				"key",
				"tags"
			],
			"additionalProperties": false
		},
		
		"imports": {
			"type": "object",
			"properties": {
				"libraries": {"$ref": "#/$defs/_string-array"},
				"modules": {"$ref": "#/$defs/_string-array"}
			},
			"required": [
				"libraries",
				"modules"
			],
			"additionalProperties": false
		},
		
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {"$ref": "#/$defs/_key"},
					"comment": {"$ref": "#/$defs/_comment"},
					"id": {
						"type": "object",
						"properties": {
							"key": {"$ref": "#/$defs/_key"},
							"label": {"$ref": "#/$defs/_label"},
							"comment": {"$ref": "#/$defs/_comment"},
							"domain-type": {"$ref": "#/$defs/_domain-type"}
						},
						"required": [
							"key",
							"label",
							"domain-type"
						],
						"additionalProperties": false
					},
					"attributes": {"$ref":"#/$defs/_attributes"},
					"links": {
						"type": "array",
						"items": {"$ref": "#/$defs/_link"}
					}
				},
				"required": [
					"key",
					"id",
					"attributes", 
					"links"
				],
				"additionalProperties": false
			}
		},
		"value-objects": {
			"type": "array",
			"items": {
				"type":"object",
				"properties": {
					"key": {"$ref": "#/$defs/_key"},
					"comment": {"$ref": "#/$defs/_comment"},
					"attributes": {"$ref": "#/$defs/_attributes"}
				}, 	
				"required": [
					"key",
					"attributes"
				],
				"additionalProperties": false
			}
		}
	},
	"required": [
		"module-info",
		"imports",
		"entities",
		"value-objects"
	],
	"additionalProperties": false
}