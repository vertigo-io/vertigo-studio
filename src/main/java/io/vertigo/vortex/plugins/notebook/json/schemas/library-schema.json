{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$id": "library-schema.json",
	
	"type": "object",
	"properties": {
		"library_info": {
			"type": "object",
			"description": "Metadata describing the current library.",
			"properties": {
				"key": {"$ref": "commons.json#/$defs/_key"},
				"comment": {"$ref": "commons.json#/$defs/_comment"},
				"tags": {"$ref": "commons.json#/$defs/_string_array"}
			},
			"required": [
				"key",
				"tags"
			],
			"additionalProperties": false
		},
		"domain_types": {
			"type": "object",
			"description": "Map of domain type definitions, where each property name is a domain type key, and its value is the domain type object.",
		 	"propertyNames": {"$ref": "commons.json#/$defs/_key"},
			"additionalProperties": {
				"type": "object",
				"properties": {
					"comment": {"$ref": "commons.json#/$defs/_comment"},
					"data_type": {
						"type": "string",
						"description": "Specifies the primitive type of the domain.",
						"enum": [
							"String",
							"Text",
							"Long",
							"Integer",
							"Double",
							"Boolean",
							"UUID",
							"Json"
						]
					}
				},
				"required": [
					"data_type"
				],
				"additionalProperties": false
			}
		}
	},
	"required": [
		"library_info",
		"domain_types"
	],
	"additionalProperties": false
}