{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
	   "key-type": {
	     "type": "string",
	     "pattern": "^[a-z]+(-[a-z]+)*$",
	     "maxLength": 30
	   },
	   "description-type": {
	   	     "type": "string",
	   	     "maxLength": 250
	   }
	 },
	"type": "object",
	"properties": {
		"module": { "$ref": "#/$defs/key-type" },
		"description": { "$ref": "#/$defs/description-type" },
		"uses": {
			"type": "object",
			"properties": {
				"libraries": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"modules": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": { "$ref": "#/$defs/key-type" },
					"description": { "$ref": "#/$defs/description-type" },
					"id": {
						"type": "object",
						"properties": {
							"key": { "$ref": "#/$defs/key-type" },
							"description": { "$ref": "#/$defs/description-type" },
							"domainType": {
								"type": "string",
								"pattern": "^do-[a-z]+$"
							}
						},
						"required": [
							"key",
							"domainType"
						]
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": { "$ref": "#/$defs/key-type" },
								"description": { "$ref": "#/$defs/description-type" },
								"domainType": {
									"type": "string",
									"pattern": "^do-[a-z]+$"
								},
								"cardinality": {
									"type": "string",
									"enum": [
										"1",
										"*",
										"?"
									]
								}
							},
							"required": [
								"key",
								"domainType"
							]
						}
					},
					"links": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": { "$ref": "#/$defs/key-type" },
								"description": { "$ref": "#/$defs/description-type" },
								"targetEntityName": {
									"type": "string",
									"pattern": "^[a-z]+$"
								},
								"cardinality": {
									"type": "string",
									"enum": [
										"1",
										"*",
										"?"
									]
								}
							},
							"required": [
								"key",
								"description",
								"targetEntityName"
							]
						}
					}
				},
				"required": [
					"key",
					"id",
					"attributes"
				]
			}
		}
	},
	"required": [
		"module",
		"uses",
		"entities"
	]
}