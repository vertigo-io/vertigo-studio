{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"module": {
			"type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 20
		},
		"description": {
			"type": "string"
		},
		"uses": {
			"type": "object",
			"properties": {
				"libraries": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"modules": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"pattern": "^[a-z]+$",
						"maxLength": 30
					},
					"description": {
						"type": "string"
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string",
									"pattern": "^[a-z]+(-[a-z]+)*$",
									"maxLength": 30
								},
								"description": {
									"type": "string"
								},
								"domainType": {
									"type": "string",
									"pattern": "^do-[a-z]+$"
								},
								"cardinality": {
									"type": "string",
									"enum": [
										"1",
										"*",
										"?"
									]
								},
								"role": {
									"type": "string",
									"enum": [
										"id",
										"data",
										"computed"
									]
								}
							},
							"required": [
								"name",
								"description",
								"domainType"
							]
						}
					},
					"links": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string",
									"pattern": "^[a-z]+(-[a-z]+)*$",
									"maxLength": 30
								},
								"description": {
									"type": "string"
								},
								"targetEntityName": {
									"type": "string",
									"pattern": "^[a-z]+$"
								},
								"cardinality": {
									"type": "string",
									"enum": [
										"1",
										"*",
										"?"
									]
								}
							},
							"required": [
								"name",
								"description",
								"targetEntityName"
							]
						}
					}
				},
				"required": [
					"name",
					"description",
					"attributes"
				]
			}
		}
	},
	"required": [
		"module",
		"uses",
		"entities"
	]
}