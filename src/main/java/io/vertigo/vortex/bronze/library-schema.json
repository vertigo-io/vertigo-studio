{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
	   "key-type": {
	     "type": "string",
	     "pattern": "^[a-z]+(-[a-z]+)*$",
	     "maxLength": 30
	   },
	   "description-type": {
	   	     "type": "string",
	   	     "maxLength": 250
	   }
	},
	"type": "object",
	"properties": {
		"library": { "$ref": "#/$defs/key-type" },
		"description": { "$ref": "#/$defs/description-type" },
		"domainTypes": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": { "$ref": "#/$defs/key-type" },
					"dataType": {
						"type": "string",
						"enum": [
							"String",
							"Text",
							"Long",
							"Integer",
							"Double",
							"Boolean",
							"Json"
						]
					}
				},
				"required": [
					"key",
					"dataType"
				]
			}
		}
	},
	"required": [
		"library",
		"domainTypes"
	]
}