{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
		"key-type": {
			"type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"comment-type": {
			"type": "string",
			"maxLength": 500
		},
		"label-type": {
			"type": "string",
			"maxLength": 100
		},
		"string-array-type": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"uniqueItems": true
		}
	},
	"type": "object",
	"properties": {
		"library": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"comment": {
					"$ref": "#/$defs/comment-type"
				},
				"tags": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"key",
				"comment",
				"tags"
			]
		},
		"domainTypes": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"$ref": "#/$defs/key-type"
					},
					"comment": {
						"$ref": "#/$defs/comment-type"
					},
					"dataType": {
						"type": "string",
						"enum": [
							"String",
							"Text",
							"Long",
							"Integer",
							"Double",
							"Boolean",
							"Json"
						]
					}
				},
				"required": [
					"key",
					"dataType"
				]
			}
		}
	},
	"required": [
		"library",
		"domainTypes"
	]
}