{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
		"_key": {
			"type": "string",
			"pattern": "^([a-z]+:?)[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"_type": {
			"type": "string",
			"pattern": "^([a-z]+:?)[a-z]+(-[a-z]+)*$"
		},
		"_comment": {
			"type": "string",
			"maxLength": 500
		},
		"_label": {
			"type": "string",
			"maxLength": 100
		},
		"_string-array": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"uniqueItems": true
		},
		"_link": {
			"type": "object",
			"properties": {
				"key": {"$ref": "#/$defs/_key"},
				"label": {"$ref": "#/$defs/_label"},
				"comment": {"$ref": "#/$defs/_comment"},
				"targetEntityKey": {"$ref": "#/$defs/_key"},
				"required": {"type": "boolean"},
				"stereotype": {
					"type": "string",
					"enum": [
						"MANY_TO_ONE",
						"ONE_TO_ONE",
						"MANY_TO_MANY"
					]
				}
			},
			"required": [
				"key",
				"label",
				"targetEntityKey",
				"required",
				"stereotype"
			]
		},
		"_value": {
			"type": "object",
			"properties": {
				"key": {"$ref": "#/$defs/_key"},
				"comment": {"$ref": "#/$defs/_comment"},
				"attributes": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"key": {"$ref": "#/$defs/_key"},
							"label": {"$ref": "#/$defs/_label"},
							"comment": {"$ref": "#/$defs/_comment"},
							"type": {"$ref": "#/$defs/_type"},
							"required": {"type": "boolean"}
						},
						"required": [
							"key",
							"label",
							"type",
							"required"
						]
					}
				}
			},
			"required": [
				"key",
				"comment",
				"attributes"
			]
		}
	},
	"type": "object",
	"properties": {
		"module": {
			"type": "object",
			"properties": {
				"key": {"$ref": "#/$defs/_key"},
				"comment": {"$ref": "#/$defs/_comment"},
				"tags": {"$ref": "#/$defs/_string-array"}
			},
			"required": [
				"key",
				"tags"
			]
		},
		"imports": {
			"type": "object",
			"properties": {
				"libraries": {"$ref": "#/$defs/_string-array"},
				"modules": {"$ref": "#/$defs/_string-array"}
			},
			"required": [
				"libraries",
				"modules"
			]
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {"$ref": "#/$defs/_key"},
					"comment": {"$ref": "#/$defs/_comment"},
					"id": {
						"type": "object",
						"properties": {
							"key": {"$ref": "#/$defs/_key"},
							"label": {"$ref": "#/$defs/_label"},
							"comment": {"$ref": "#/$defs/_comment"},
							"type": {"$ref": "#/$defs/_type"}
						},
						"required": [
							"key",
							"label",
							"type"
						]
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": {"$ref": "#/$defs/_key"},
								"label": {"$ref": "#/$defs/_label"},
								"comment": {"$ref": "#/$defs/_comment"},
								"type": {"$ref": "#/$defs/_type"},
								"required": {"type": "boolean"}
							},
							"required": [
								"key",
								"label",
								"type",
								"required"
							]
						}
					},
					"links": {
						"type": "array",
						"items": {"$ref": "#/$defs/_link"}
					}
				},
				"required": [
					"key",
					"comment",
					"id",
					"attributes"
				]
			}
		},
		"values": {
			"type": "array",
			"items": {"$ref": "#/$defs/_value"}
		}
	},
	"required": [
		"module",
		"imports",
		"entities",
		"valueObjects"
	]
}