{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
		"key-type": {
			"type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"description-type": {
			"type": "string",
			"maxLength": 250
		},
		"string-array-type": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"minItems": 0,
			"uniqueItems": true
		},
		"cardinality-type": {
			"type": "string",
			"enum": [
				"1",
				"*",
				"?"
			]
		}
	},
	"type": "object",
	"properties": {
		"module": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"description": {
					"$ref": "#/$defs/description-type"
				},
				"tags": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"key",
				"description",
				"tags"
			]
		},
		"uses": {
			"type": "object",
			"properties": {
				"libraries": {
					"$ref": "#/$defs/string-array-type"
				},
				"modules": {
					"$ref": "#/$defs/string-array-type"
				}
			}
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"$ref": "#/$defs/key-type"
					},
					"description": {
						"$ref": "#/$defs/description-type"
					},
					"id": {
						"type": "object",
						"properties": {
							"key": {
								"$ref": "#/$defs/key-type"
							},
							"description": {
								"$ref": "#/$defs/description-type"
							},
							"domainType": {
								"type": "string",
								"pattern": "^do-[a-z]+$"
							}
						},
						"required": [
							"key",
							"domainType"
						]
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": {
									"$ref": "#/$defs/key-type"
								},
								"description": {
									"$ref": "#/$defs/description-type"
								},
								"domainType": {
									"type": "string",
									"pattern": "^do-[a-z]+$"
								},
								"cardinality": {
									"$ref": "#/$defs/cardinality-type"
								}
							},
							"required": [
								"key",
								"domainType"
							]
						}
					},
					"links": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": {
									"$ref": "#/$defs/key-type"
								},
								"description": {
									"$ref": "#/$defs/description-type"
								},
								"targetEntityName": {
									"type": "string",
									"pattern": "^[a-z]+$"
								},
								"cardinality": {
									"$ref": "#/$defs/cardinality-type"
								}
							},
							"required": [
								"key",
								"targetEntityName"
							]
						}
					}
				},
				"required": [
					"key",
					"id",
					"attributes",
					"links"
				]
			}
		}
	},
	"required": [
		"module",
		"uses",
		"entities"
	]
}