{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
		"key-type": {
			"type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"domain-type-type": {
			"type": "string",
			"pattern": "^do-[a-z]+$"
		},
		"description-type": {
			"type": "string",
			"maxLength": 250
		},
		"string-array-type": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"minItems": 0,
			"uniqueItems": true
		},
		"cardinality-type": {
			"type": "string",
			"enum": [
				"1",
				"*",
				"?"
			]
		},
		"link-type": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"description": {
					"$ref": "#/$defs/description-type"
				},
				"targetEntityKey": {
					"$ref": "#/$defs/key-type"
				},
				"cardinality": {
					"$ref": "#/$defs/cardinality-type"
				}
			},
			"required": [
				"key",
				"targetEntityKey",
				"cardinality"
			]
		},
		"part-of-type": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"description": {
					"$ref": "#/$defs/description-type"
				},
				"targetEntityKey": {
					"$ref": "#/$defs/key-type"
				}	
			},
			"required": [
				"key",
				"targetEntityKey"			]
		}
	},
	
	"type": "object",
	"properties": {
		"module": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"description": {
					"$ref": "#/$defs/description-type"
				},
				"tags": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"key",
				"description",
				"tags"
			]
		},
		"imports": {
			"type": "object",
			"properties": {
				"libraries": {
					"$ref": "#/$defs/string-array-type"
				},
				"modules": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"libraries",
				"modules"
			]
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"$ref": "#/$defs/key-type"
					},
					"description": {
						"$ref": "#/$defs/description-type"
					},
					"id": {
						"type": "object",
						"properties": {
							"key": {
								"$ref": "#/$defs/key-type"
							},
							"description": {
								"$ref": "#/$defs/description-type"
							},
							"domainType": {
								"$ref": "#/$defs/domain-type-type"
							}
						},
						"required": [
							"key",
							"description",
							"domainType"
						]
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": {"$ref": "#/$defs/key-type"},
								"description": {"$ref": "#/$defs/description-type"},
								"domainType": {"$ref": "#/$defs/domain-type-type"},
								"cardinality": {"$ref": "#/$defs/cardinality-type"}
							},
							"required": [
								"key",
								"domainType"
							]
						}
					},
					"partOf": {
						"type": "object",
						"items": {"$ref": "#/$defs/part-of-type"}
					},
					"link": {
						"type": "array",
						"items": {"$ref": "#/$defs/link-type"}
					}
				},
				"required": [
					"key",
					"id",
					"attributes"
				]
			}
		}
	},
	"required": [
		"module",
		"imports",
		"entities"
	]
}