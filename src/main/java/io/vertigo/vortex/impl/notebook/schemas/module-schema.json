{
	"$schema": "http://json-schema.org/draft/2020-12/schema",
	"$defs": {
		"key-type": {
			"type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 30
		},
		"domain-type-type": {
			"type": "string",
			"pattern": "^do-[a-z]+$"
		},
		"comment-type": {
			"type": "string",
			"maxLength": 500
		},
		"label-type": {
			"type": "string",
			"maxLength": 100
		},
		"string-array-type": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"uniqueItems": true
		},
		"link-type": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"label": {
					"$ref": "#/$defs/label-type"
				},
				"comment": {
					"$ref": "#/$defs/comment-type"
				},
				"targetEntityKey": {
					"$ref": "#/$defs/key-type"
				},
				"required": {
					"type": "boolean"
				},
				"stereotype": {
					"type": "string",
					"enum": [
						"MANY_TO_ONE",
						"ONE_TO_ONE",
						"MANY_TO_MANY"
					]
				}
			},
			"required": [
				"key",
				"label",
				"targetEntityKey",
				"required",
				"stereotype"
			]
		},
		"valueObject-type": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"comment": {
					"$ref": "#/$defs/comment-type"
				},
				"attributes": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"key": {
								"$ref": "#/$defs/key-type"
							},
							"label": {
								"$ref": "#/$defs/label-type"
							},
							"comment": {
								"$ref": "#/$defs/comment-type"
							},
							"type": {
								"$ref": "#/$defs/domain-type-type"
							},
							"required": {
								"type": "boolean"
							}
						},
						"required": [
							"key",
							"label",
							"type",
							"required"
						]
					}
				}
			},
			"required": [
				"key",
				"comment",
				"attributes"
			]
		}
	},
	"type": "object",
	"properties": {
		"module": {
			"type": "object",
			"properties": {
				"key": {
					"$ref": "#/$defs/key-type"
				},
				"comment": {
					"$ref": "#/$defs/comment-type"
				},
				"tags": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"key",
				"comment",
				"tags"
			]
		},
		"imports": {
			"type": "object",
			"properties": {
				"libraries": {
					"$ref": "#/$defs/string-array-type"
				},
				"modules": {
					"$ref": "#/$defs/string-array-type"
				}
			},
			"required": [
				"libraries",
				"modules"
			]
		},
		"entities": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"$ref": "#/$defs/key-type"
					},
					"comment": {
						"$ref": "#/$defs/comment-type"
					},
					"id": {
						"type": "object",
						"properties": {
							"key": {
								"$ref": "#/$defs/key-type"
							},
							"label": {
								"$ref": "#/$defs/label-type"
							},
							"comment": {
								"$ref": "#/$defs/comment-type"
							},
							"type": {
								"$ref": "#/$defs/domain-type-type"
							}
						},
						"required": [
							"key",
							"label",
							"type"
						]
					},
					"attributes": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"key": {
									"$ref": "#/$defs/key-type"
								},
								"label": {
									"$ref": "#/$defs/label-type"
								},
								"comment": {
									"$ref": "#/$defs/comment-type"
								},
								"type": {
									"$ref": "#/$defs/domain-type-type"
								},
								"required": {
									"type": "boolean"
								}
							},
							"required": [
								"key",
								"label",
								"type",
								"required"
							]
						}
					},
					"links": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/link-type"
						}
					}
				},
				"required": [
					"key",
					"comment",
					"id",
					"attributes"
				]
			}
		},
		"valueObjects": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/valueObject-type"
			}
		}
	},
	"required": [
		"module",
		"imports",
		"entities",
		"valueObjects"
	]
}