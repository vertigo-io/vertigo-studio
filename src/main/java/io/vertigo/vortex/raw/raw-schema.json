{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
			"pattern": "^[a-z]+(-[a-z]+)*$",
			"maxLength": 20
          }
        }
      },
      "required": ["description"]
    },
    "domainTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
			"pattern": "^do-[a-z]+$", 
			"maxLength": 20
          },
          "dataType": {
            "type": "string",
            "enum": ["String", "Text", "Long", "Integer", "Double", "Boolean", "Json"]
          }
        },
        "required": ["name", "dataType"]
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
			"pattern": "^[a-z]+$", 
			"maxLength": 30
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
				  "pattern": "^[a-z]+(-[a-z]+)*$", 
				  "maxLength": 30
                },
                "domainType": {
                  "type": "string",
                  "pattern": "^do-[a-z]+$"
                },
                "cardinality": {
                  "type": "string",
                  "enum": ["1", "*", "?"]
                },
                "role": {
                  "type": "string",
                  "enum": ["id", "data", "computed"]
                }
              },
              "required": ["name", "domainType", "cardinality"]
            }
          }
        },
        "required": ["name", "attributes"]
      }
    }
  },
  "required": ["header", "domainTypes", "entities"]
}