{
	module-info: {
		key: "author",
		comment: "List of authors",
		tags: []
	},

	imports: {
		libraries: ["core"],
		modules: []
	},
	
	entities: {
		/* Author */
		author: {
			comment: "An author",
			id: {key: "id",  domain-type: "do-id", label: "Identifier"},
			traits: ["producer"],
			attributes: {
				first-name: { domain-type: "do-label", label: "First name", required: true },
				last-name : { domain-type: "do-label", label: "Last name", required: false },
				contact-info : { domain-type: "json:contact-info", label: "contact", required: false } 
			},	
			links: {
				publisher: { stereotype: "MANY_TO_ONE", label: "Publisher", target-entity-key: "publisher" },
				author-publisher-agreement: {stereotype: "MANY_TO_MANY", label: "List of publishers", comment: "Agreement between author and publisher for a book", target-entity-key: "publisher"	}
			}
		},
		
		/* Publisher */
		publisher: {
			comment: "A book publisher",
			id: { key: "id", domain-type: "do-id", label: "Identifier of the publisher"},
			traits: ["producer"],			
			attributes: {
				name: { domain-type: "do-label", label: "Name of the publisher", required: true }
			},
			links: {}
		}
	},
	
	value-objects: {
		contact-info: {
			comment: "Contact info of an author",
			attributes: {
				email: { domain-type: "do-email", label: "Email", required: true 	},
				phone: { domain-type: "do-phone", label: "Phone", required: false }
			}
		}
	},
	traits: {
		producer: {
			attributes: {
				created-by: { domain-type: "do-label", label: "Created by", required: true },
				created-at: { domain-type: "do-instant", label: "Created at", required: true }
			}
		}
	}
}