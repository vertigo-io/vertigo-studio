{
	module_info: {
		key: "author",
		_comment: "List of authors",
		_tags: []
	},

	imports: {
		libraries: ["core"],
		modules: []
	},
	
	entities: {
		/* Author */
		author: {
			_comment: "An author",
			id: {key: "id",  domain_type: "do_id", label: "Identifier"},
			_traits: ["producer"],
			attributes: {
				first_name: {domain_type: "do_label", label: "First name", required: true },
				last_name : {domain_type: "do_label", label: "Last name", required: false },
				contact_info : {domain_type: "json:contact_info", label: "contact", required: false } 
			},	
			links: {
				publisher: {stereotype: "MANY_TO_ONE", label: "Publisher", target_entity_key: "publisher" },
				author_publisher_agreement: {stereotype: "MANY_TO_MANY", label: "List of publishers", comment: "Agreement between author and publisher for a book", target_entity_key: "publisher"	}
			}
		},
		
		/* Publisher */
		publisher: {
			_comment: "A book publisher",
			id: {key: "id", domain_type: "do_id", label: "Identifier of the publisher"},
			_traits: ["producer"],			
			attributes: {
				name: {domain_type: "do_label", label: "Name of the publisher", required: true }
			},
			links: {}
		}
	},
	
	value_objects: {
		contact_info: {
			_comment: "Contact info of an author",
			email: {domain_type: "do_email", label: "Email", required: true 	},
			phone: {domain_type: "do_phone", label: "Phone", required: false }
		}
	},
	traits: {
		producer: {
			attributes: {
				created_by: {domain_type: "do_label", label: "Created by", required: true },
				created_at: {domain_type: "do_instant", label: "Created at", required: true }
			}
		}
	}
}