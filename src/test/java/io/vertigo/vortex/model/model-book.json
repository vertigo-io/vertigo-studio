{
  "module": "bibliotheque",
  
  "header": {
	"description": "modélisation d'une bibliothèque",
	"tags":["books", "authors"]
  }, 	
  
  "domainTypes": 
  [
    { "name": "do-label", "dataType": "String"},
	{ "name": "do-id", "dataType": "Long"}
  ],
  
  "entities": 
  [
    { 
	  "name": "book",
      "attributes": [
		{ "name": "id", "domainType": "do-id", "cardinality": "1", "role":"id"},
