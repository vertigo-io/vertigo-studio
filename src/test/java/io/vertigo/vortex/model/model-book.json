        { "name": "isbn", "domainType": "do-label", "cardinality": "1"},
        { "name": "author","domainType": "do-author", "cardinality": "1"}
      ]
    }, 
	{ 
	  "name": "author",
	  "attributes": [
		{ "name": "id", "domainType": "do-id", "role":"id"},
	    { "name": "first-name", "domainType": "do-label", "role":"data", "cardinality": "1"},
	    {"name": "last-name", "domainType": "do-label"}
	  ]
	}
  ]
}
